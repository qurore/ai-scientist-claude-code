# Copy to .env and adjust. The bridge/hooks read these from the environment.
# (.env is gitignored. Claude Code does not auto-load .env — `source .env` in a
#  shell, or set these in .claude/settings.json "env", to apply them.)

# --- Autopilot (Stop hook) ---
# 1 = run the whole pipeline hands-off; 0 = pause between stages (default).
AISCI_AUTOPILOT=0
# Max auto-advances before the Stop hook forces a check-in.
AISCI_AUTOPILOT_MAX=8

# --- Bridge: which Claude models back each tier ---
# Defaults live in bridge/model_map.py; override here if desired.
AISCI_CLAUDE_MODEL_BIG=claude-opus-4-8
AISCI_CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
AISCI_CLAUDE_MODEL_SMALL=claude-haiku-4-5-20251001

# --- Bridge: headless claude invocation ---
AISCI_CLAUDE_BIN=claude
AISCI_CLAUDE_TIMEOUT=1200
AISCI_CLAUDE_MAX_RETRIES=4
# AISCI_MODEL_MAP=config/model_map.json
# AISCI_CACHE_DIR=.aisci_cache

# --- Optional external services (used by ideation/writeup if present) ---
# Semantic Scholar works without a key but a key raises rate limits.
# S2_API_KEY=

# --- Zenodo deposit (publish a finalized paper + get a DOI) ---
# The ONLY secret needed is a Zenodo Personal Access Token (scopes:
#   deposit:write, deposit:actions). Create at:
#   prod:    https://zenodo.org/account/settings/applications/tokens/new/
#   sandbox: https://sandbox.zenodo.org/account/settings/applications/tokens/new/
# Test on SANDBOX first (separate login + token); published DOIs are PERMANENT.
# These live ONLY in .env (gitignored) — never commit them (this repo is public).
# ZENODO_SANDBOX_TOKEN=
# ZENODO_TOKEN=
# Metadata (NOT secret) — ORCID is an identifier, not an API key:
# ORCID_ID=0000-0000-0000-0000
# ZENODO_AUTHOR_NAME=Family, Given
# ZENODO_AUTHOR_AFFILIATION=
# ZENODO_DEFAULT_LICENSE=cc-by-4.0
